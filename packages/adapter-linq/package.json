{
  "name": "@linq-chat-sdk/adapter-linq",
  "version": "0.0.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsc --project tsconfig.json --watch",
    "build": "tsc --project tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check"
  },
  "dependencies": {
    "@linqapp/sdk": "^0.22.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.6",
    "chat": "^4.26.0",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "chat": "^4.26.0"
  }
}
