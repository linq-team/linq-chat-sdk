{
  "name": "@linqapp/chat-sdk-adapter",
  "version": "0.1.0",
  "description": "Linq adapter for Chat SDK — build chatbots that talk over iMessage and SMS",
  "license": "Apache-2.0",
  "author": "Linq <support@linq.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/linq-team/linq-chat-sdk.git",
    "directory": "packages/adapter-linq"
  },
  "homepage": "https://github.com/linq-team/linq-chat-sdk/tree/main/packages/adapter-linq#readme",
  "bugs": {
    "url": "https://github.com/linq-team/linq-chat-sdk/issues"
  },
  "keywords": [
    "linq",
    "imessage",
    "sms",
    "chat",
    "chatbot",
    "chat-sdk",
    "adapter"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsc --project tsconfig.json --watch",
    "build": "tsc --project tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check"
  },
  "dependencies": {
    "@linqapp/sdk": "^0.22.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.6",
    "chat": "^4.28.1",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "chat": "^4.28.1"
  }
}
